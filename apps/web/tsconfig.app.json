{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "types": ["vite/client"],

    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@auth/components": ["src/features/auth/components"],
      "@auth/components/*": ["src/features/auth/components/*"],
      "@auth/types": ["src/features/auth/types"],
      "@auth/service": ["src/features/auth/service"],
      "@appUtils": ["src/utils"],
      "@authSlice": ["src/features/auth/slice"],
      "@kanban/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src"]
}
