{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",

    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/*"]
    }
  }
}
